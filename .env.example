# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Optional: override the default project / entity set in configs/train_*.yaml
# WANDB_PROJECT=rl-memory-curriculum
# WANDB_ENTITY=your_wandb_username_or_team

# ── LLM-as-Judge (OpenAI-compatible) ─────────────────────────────────────────
# Required only for --llm-judge evaluation step.
# Works with OpenAI, Azure OpenAI, or any OpenAI-compatible endpoint.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a custom base URL (Azure OpenAI, local vLLM, etc.)
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/
